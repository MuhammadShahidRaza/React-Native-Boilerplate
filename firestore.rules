rules_version = '2';
// Auth is handled by the Laravel API. Firestore is used for chat, presence, and worker live location.
// Deploy: Firebase Console → Firestore → Rules, or `firebase deploy --only firestore:rules`
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
