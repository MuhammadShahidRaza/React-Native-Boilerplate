# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/vendor/bundle/

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*

# testing
/coverage

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Firebase / Google — DO NOT commit real secrets.
#
# IMPORTANT (read this): Add YOUR own app’s Firebase files from the Firebase
# Console. If you are not using the same Firebase project as this boilerplate,
# replace any template / temp placeholders with your own JSON + plist:
#   • Android → android/app/google-services.json
#   • iOS     → ios/<YourApp>/GoogleService-Info.plist
# The patterns below keep those files (and local env secrets) out of git.
google-services.json
GoogleService-Info.plist
*GoogleService-Info*.plist
.env.production
.env.development
firebaseConfig.ts
