# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# Never set SKIP_BUNDLING=1 in .xcode.env.local for device/Archive builds.
# It skips embedding main.jsbundle and the Release app crashes immediately on launch.

# Pin hermesc to this repo. Xcode/Cursor can inherit HERMES_CLI_PATH from another workspace.
_ios_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_hermes_npm="${_ios_dir}/../node_modules/hermes-compiler/hermesc/osx-bin/hermesc"
_hermes_pods="${PODS_ROOT:-${_ios_dir}/Pods}/hermes-engine/destroot/bin/hermesc"
if [ -x "${_hermes_npm}" ]; then
  export HERMES_CLI_PATH="${_hermes_npm}"
elif [ -x "${_hermes_pods}" ]; then
  export HERMES_CLI_PATH="${_hermes_pods}"
fi
