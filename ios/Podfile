# # Resolve react_native_pods.rb with node to allow for hoisting
# require Pod::Executable.execute_command('node', ['-p',
#   'require.resolve(
#     "react-native/scripts/react_native_pods.rb",
#     {paths: [process.argv[1]]},
#   )', __dir__]).strip


def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

ENV['RCT_NEW_ARCH_ENABLED'] = '1'

platform :ios, min_ios_version_supported
prepare_react_native_project!

# RN 0.85 + New Arch + use_frameworks :static: RNFB as frameworks breaks Clang explicit modules
# (e.g. RCTPromiseRejectBlock / RCT_EXPORT_MODULE in RNFBMessaging). Build RNFB pods as static libraries.
# See https://github.com/invertase/react-native-firebase/issues/8883
pre_install do |installer|
  installer.pod_targets.each do |pod|
    if pod.name.start_with?('RNFB')
      def pod.build_type
        Pod::BuildType.static_library
      end
    end
  end
end

setup_permissions([
    # 'AppTrackingTransparency',
    # 'Bluetooth',
    # 'Calendars',
    # 'CalendarsWriteOnly',
    'Camera',
    # 'Contacts',
    # 'FaceID',
    # 'LocationAccuracy',
    'LocationAlways',
    'LocationWhenInUse',
    'MediaLibrary',
    # 'Microphone',
    # 'Motion',
    'Notifications',
    'PhotoLibrary',
    # 'PhotoLibraryAddOnly',
    # 'Reminders',
    # 'Siri',
    # 'SpeechRecognition',
    # 'StoreKit',
])

target 'yourappname' do

# React Native Maps dependencies

rn_maps_path = '../node_modules/react-native-maps'
pod 'react-native-maps/Google', :path => rn_maps_path

  config = use_native_modules!
  
  linkage = ENV['USE_FRAMEWORKS']
  if linkage != nil
    Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
    use_frameworks! :linkage => linkage.to_sym
  else
    use_frameworks! :linkage => :static
  end
  $RNFirebaseAsStaticFramework = true
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # Xcode 26+: StripeSwiftInterop.h used NSUInteger for STPPaymentStatus; Swift exports NSInteger — hard error in 0.58.x.
    # Fixed upstream in @stripe/stripe-react-native >= 0.61.0; patch locally until you can bump the npm package + pods.
    stripe_swift_interop = File.expand_path('../node_modules/@stripe/stripe-react-native/ios/StripeSwiftInterop.h', __dir__)
    if File.exist?(stripe_swift_interop)
      contents = File.read(stripe_swift_interop)
      patched = contents.gsub('typedef NS_ENUM(NSUInteger, STPPaymentStatus);', 'typedef NS_ENUM(NSInteger, STPPaymentStatus);')
      if contents != patched
        File.write(stripe_swift_interop, patched)
        Pod::UI.puts '[Stripe] Patched StripeSwiftInterop.h for Xcode 26+ (STPPaymentStatus)'.green
      end
    end

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26.4+ / Apple Clang: fmt 11 enables consteval via __cpp_consteval but the
    # compiler rejects FMT_COMPILE_STRING sites (see fmtlib/fmt#4740). C++17 disables that path.
    # Static frameworks + mixed pods: allow non-modular includes (common RN + Firebase setup).
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |cfg|
        cfg.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        # Apple Silicon hosts: skip Intel simulator; avoids flaky Swift explicit modules / mixed slices with some pods.
        cfg.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'x86_64'
        if target.name == 'fmt'
          cfg.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end
  end
end
